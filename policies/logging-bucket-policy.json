{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3LogDeliveryWrite",
      "Effect": "Allow",
      "Principal": {
        "Service": "logging.s3.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::account-b-crossacct-logs-<random>/access-logs/*",
      "Condition": {
        "ArnLike": {
          "aws:SourceArn": "arn:aws:s3:::account-b-crossacct-demo-<random>"
        }
      }
    }
  ]
}
